@@ -41,6 +41,10 @@
 #	include <fcntl.h>
 #elif defined(LMMS_BUILD_WIN32)
 #	include <windows.h>
+#elif defined(__EMSCRIPTEN__)
+	// WASM: single-threaded, use plain heap as shared memory
+	#include <cstdlib>
+	#include <cstring>
 #else
 #	error "No shared memory implementation available"
 #endif
@@ -255,6 +259,59 @@ private:
 	std::size_t m_arraySize = 0; // non-zero if it's an array
 };
 
+#elif defined(__EMSCRIPTEN__)
+
+namespace {
+
+// WASM single-threaded: use heap as shared memory (no actual IPC needed)
+
+} // namespace
+
+class SharedMemoryImpl
+{
+public:
+	SharedMemoryImpl(const std::string& key, bool readOnly, bool isArray)
+		: m_key{key}, m_readOnly{readOnly}
+	{
+		// For WASM, we can't open existing shared memory across processes,
+		// but within LMMS, this is used for inter-thread communication which
+		// doesn't apply in WASM single-threaded mode. Just allocate heap.
+		m_size = 4096; // minimum usable size
+		m_mapping = new char[m_size];
+		if (isArray) { m_arraySize = static_cast<Header*>(m_mapping)->size; }
+	}
+
+	SharedMemoryImpl(const std::string& key, std::size_t size, bool readOnly, bool isArray)
+		: m_key{key}, m_readOnly{readOnly}, m_size{size}
+	{
+		if (isArray) {
+			m_size += sizeof(Header);
+			m_arraySize = size;
+		}
+		m_mapping = new char[m_size];
+		if (isArray) { new (m_mapping) Header{static_cast<std::uint64_t>(size)}; }
+	}
+
+	SharedMemoryImpl(const SharedMemoryImpl&) = delete;
+	SharedMemoryImpl& operator=(const SharedMemoryImpl&) = delete;
+
+	~SharedMemoryImpl() { delete[] static_cast<char*>(m_mapping); }
+
+	auto get() const noexcept -> void* {
+		return m_arraySize > 0
+			? static_cast<char*>(m_mapping) + sizeof(Header)
+			: m_mapping;
+	}
+	auto arraySize() const noexcept -> std::size_t { return m_arraySize; }
+
+private:
+	std::string m_key;
+	bool m_readOnly = false;
+	std::size_t m_size = 0;
+	std::size_t m_arraySize = 0;
+	void* m_mapping = nullptr;
+};
+
 #endif
 
