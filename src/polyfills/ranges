#ifndef LMMS_RANGES_POLYFILL
#define LMMS_RANGES_POLYFILL

#include <iterator>

namespace std::ranges {

// Minimal subrange = {begin iterator, end sentinel}
template <typename I, typename S = I>
class subrange {
	I m_begin;
	S m_end;

public:
	subrange() = default;
	constexpr subrange(I begin, S end) : m_begin(begin), m_end(end) {}

	constexpr I begin() const { return m_begin; }
	constexpr S end() const { return m_end; }
	constexpr bool empty() const { return m_begin == m_end; }

	constexpr auto size() const {
		return static_cast<size_t>(m_end - m_begin);
	}
};

} // namespace std::ranges

#endif
